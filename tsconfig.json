{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["DOM", "ES2017"],

    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "types": ["vite/client"]
  },
  "include": ["src"]
}